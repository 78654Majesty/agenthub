# ============================================
# AgentHub — 生产环境
# 用法: cp .env.prod .env → 填入密钥 → docker compose up -d --build
# ⚠️ .env 已被 gitignore，密钥只存在于部署机器上
# ============================================

# --- Gateway ---
NODE_ENV=production
DATABASE_URL=file:/app/data/agenthub.db?journal_mode=WAL
JWT_SECRET=

# --- Solana ---
SOLANA_RPC_URL=
PLATFORM_WALLET_SECRET_KEY=
USDC_MINT_ADDRESS=

# --- ERC-8004 ---
AGENTHUB_COLLECTION_POINTER=
ERC8004_INDEXER_URL=

# --- IPFS (Pinata) ---
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# --- AI ---
ANTHROPIC_API_KEY=
